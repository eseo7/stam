{
  "version": "0.1",
  "description": "STAM Common UI contract inspection targets — Detail Drawer common assets v0.1 (board migration pending).",
  "globalContracts": {
    "commonDrawerShell": {
      "classes": [
        "stam-drawer",
        "stam-drawer-head",
        "stam-drawer-body",
        "stam-drawer-foot"
      ],
      "notes": "Drawer shell container classes shared across boards."
    },
    "commonButton": {
      "classes": ["stam-btn"],
      "notes": "Shared button class; screen-specific btn aliases may coexist during migration."
    },
    "customSelect": {
      "classes": ["stam-cs", "stam-cs-trigger"],
      "renderers": ["STAM.customSelect"],
      "cssAssets": ["stam.custom-select.css"],
      "status": "active"
    },
    "formControls": {
      "cssAssets": ["stam.form-controls.css"],
      "classes": ["stam-form-field", "stam-input", "stam-select", "stam-textarea"],
      "status": "active"
    },
    "detailDrawer": {
      "classes": ["stam-detail"],
      "renderers": ["STAM.detailDrawer"],
      "cssAssets": ["stam.detail-drawer.css"],
      "jsAssets": ["stam.detail-drawer.js"],
      "cssPath": "stam/css/stam.detail-drawer.css",
      "jsPath": "stam/js/stam.detail-drawer.js",
      "status": "active",
      "notes": "Common detail drawer body assets exist in repo. Board adoption tracked per-target as WARN until migration PRs."
    }
  },
  "detailLayoutSignals": {
    "patterns": ["innerHTML", "insertAdjacentHTML"],
    "notes": "JS that builds detail drawer body via string templates — legacy pattern to reduce over time."
  },
  "targets": [
    {
      "id": "requirements",
      "label": "요구사항정의서",
      "htmlPath": "stam/pages/boards/requirements.html",
      "jsPaths": [
        "stam/js/stam.requirements.js",
        "stam/js/stam.requirements-crud.js",
        "stam/js/stam.requirements-cycle.js"
      ],
      "cssPaths": ["stam/css/stam.requirements.css"],
      "expectedCommonAssets": [
        "stam.drawer.css",
        "stam.detail-drawer.css",
        "stam.form-controls.css",
        "stam.buttons.css",
        "stam.custom-select.css"
      ],
      "expectedCommonClasses": [
        "stam-drawer",
        "stam-drawer-head",
        "stam-drawer-body",
        "stam-drawer-foot",
        "stam-btn",
        "stam-detail"
      ],
      "expectedCommonRenderers": ["STAM.customSelect", "STAM.detailDrawer"],
      "knownLegacyPrefixes": ["rq-"],
      "knownLegacyNotes": "Detail drawer body tabs use STAM.detailDrawer + stam-detail* (PR #258). Shell/tabs/register/edit still use rq-* legacy classes.",
      "status": "baseline-warn",
      "failOnMissingFile": true
    },
    {
      "id": "menu-screen-list",
      "label": "메뉴구조/화면목록",
      "htmlPath": "stam/pages/boards/menu-screen-list.html",
      "jsPaths": [
        "stam/js/stam.menu-screen-list.js",
        "stam/js/stam.menu-screen-crud.js",
        "stam/js/stam.menu-screen-cycle.js"
      ],
      "cssPaths": ["stam/css/stam.menu-screen-list.css"],
      "expectedCommonAssets": [
        "stam.drawer.css",
        "stam.detail-drawer.css",
        "stam.custom-select.css",
        "stam.form-controls.css",
        "stam.buttons.css"
      ],
      "expectedCommonClasses": [
        "stam-drawer",
        "stam-drawer-head",
        "stam-drawer-body",
        "stam-drawer-foot",
        "stam-drawer-tabs",
        "stam-drawer-tab",
        "stam-drawer-form-area",
        "stam-form-section",
        "stam-btn",
        "stam-cs",
        "stam-detail"
      ],
      "expectedCommonRenderers": ["STAM.customSelect", "STAM.detailDrawer"],
      "knownLegacyPrefixes": ["msl-"],
      "knownLegacyNotes": "Detail drawer body tabs use STAM.detailDrawer + stam-detail* (PR #257). CRUD drawer shell/tabs/forms migrated to stam-* common classes (PR #259). Legacy msl-* static demo drawers and cycle.js row markup remain.",
      "status": "baseline-warn",
      "failOnMissingFile": true
    },
    {
      "id": "wbs",
      "label": "WBS",
      "htmlPath": "stam/pages/boards/wbs.html",
      "jsPaths": [
        "stam/js/stam.wbs.js",
        "stam/js/stam.wbs-crud.js",
        "stam/js/stam.wbs-cycle.js"
      ],
      "cssPaths": ["stam/css/stam.wbs.css"],
      "expectedCommonAssets": [
        "stam.drawer.css",
        "stam.buttons.css"
      ],
      "expectedCommonClasses": [
        "stam-btn"
      ],
      "expectedCommonRenderers": [],
      "knownLegacyPrefixes": ["wbs-"],
      "knownLegacyNotes": "Full legacy drawer: wbs-drawer / wbs-drawer-panel / wbs-drawer-* structure. No stam-drawer shell. Detail layout built via innerHTML in stam.wbs.js. Partial stam-btn adoption in footer/toolbar only.",
      "status": "knownLegacy",
      "failOnMissingFile": true
    },
    {
      "id": "screen-specification",
      "label": "화면설계서",
      "htmlPath": "stam/pages/boards/screen-specification.html",
      "jsPaths": [
        "stam/js/stam.screen-specification.js",
        "stam/js/stam.screen-specification-crud.js",
        "stam/js/stam.screen-specification-cycle.js"
      ],
      "cssPaths": ["stam/css/stam.screen-specification.css"],
      "expectedCommonAssets": [
        "stam.drawer.css",
        "stam.custom-select.css"
      ],
      "expectedCommonClasses": [
        "stam-drawer-foot",
        "stam-btn"
      ],
      "expectedCommonRenderers": ["STAM.customSelect"],
      "knownLegacyPrefixes": ["ssv2-", "ss-"],
      "knownLegacyNotes": "Drawer uses ssv2-drawer dedicated structure (not stam-drawer shell). Footer partially uses stam-drawer-foot. Large inline ssv2-* CSS block in HTML. Detail panels built via innerHTML in screen-specification-crud.js.",
      "status": "knownLegacy",
      "failOnMissingFile": true
    },
    {
      "id": "functional-specification",
      "label": "기능정의서",
      "htmlPath": "stam/pages/boards/functional-specification.html",
      "jsPaths": [
        "stam/js/stam.functional-specification.js",
        "stam/js/stam.functional-definition-crud.js",
        "stam/js/stam.functional-definition-cycle.js"
      ],
      "cssPaths": ["stam/css/stam.functional-specification.css"],
      "expectedCommonAssets": [
        "stam.drawer.css",
        "stam.form-controls.css",
        "stam.custom-select.css",
        "stam.buttons.css"
      ],
      "expectedCommonClasses": [
        "stam-drawer",
        "stam-drawer-head",
        "stam-drawer-body",
        "stam-drawer-foot",
        "stam-btn"
      ],
      "expectedCommonRenderers": ["STAM.customSelect"],
      "knownLegacyPrefixes": ["fn-"],
      "knownLegacyNotes": "Drawer shell partially uses stam-drawer*. Detail body retains fn-* dedicated classes (fn-dw-*, fn-fs, fn-ffield). No shared detail renderer.",
      "status": "baseline-warn",
      "failOnMissingFile": true
    }
  ]
}
