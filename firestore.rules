rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    /*
     * STAM Firestore Rules
     *
     * PR #297 (baseline):
     *   Deny-by-default only; helper `signedIn()` defined but unused.
     *
     * PR #298:
     *   Firestore layout finalized as `projects/{projectId}/**`
     *   subcollections. Active-project-member read gate is opened
     *   through `projects/{projectId}/members/{uid}`.
     *
     * PR #306:
     *   Authenticated users can discover only their own membership records
     *   through constrained `collectionGroup('members')` queries by uid or
     *   emailNormalized. This enables login-time routing before a projectId
     *   has been selected.
     *
     * PR #358:
     *   Requirements write opened for active members with role owner/admin/editor.
     *   Viewer remains read-only. Requirement delete stays closed.
     *
     * FS-1 (functionalSpecifications):
     *   Functional-spec write opened for active members with role owner/admin/editor.
     *   Viewer remains read-only. Functional-spec delete stays closed.
     *   Collection path: projects/{projectId}/functionalSpecifications/{functionalSpecId}
     *
     * FS-6A (functionalSpecifications counter):
     *   FN_### code counter at projects/{projectId}/counters/functionalSpecifications.
     *   Writer roles: owner/admin/editor only. Counter delete denied.
     *
     * WBS-1:
     *   WBS write opened for active project members with role owner/admin/editor.
     *   Viewer remains read-only. Delete stays closed.
     *   WBS-### counter added at projects/{projectId}/counters/wbsItems.
     *
     * ScreenSpec-1:
     *   screenSpecs write opened for active project members with role owner/admin/editor.
     *   Viewer remains read-only. Delete stays closed.
     *   SCR-### counter added at projects/{projectId}/counters/screenSpecs.
     *
     *   Signed-in users may create or update only their own `users/{uid}`
     *   document for Google login bootstrap. Client cannot change `status`,
     *   `provider`, `userId`, or `createdAt` on update. Unopened artifact
     *   collections (screenFields, screenActions, artifactLinks)
     *   remain write-closed.
     *
     *   - Rules gate is UID-based: allowed iff `projects/{projectId}/
     *     members/{request.auth.uid}` exists and .status == "active".
     *   - `email` / `emailNormalized` are stored on the member doc for
     *     invite / audit / display / future bootstrap.
     *   - Role-scoped writes are opened per collection (requirements,
     *     functionalSpecifications, wbsItems). Unopened artifacts remain closed.
     *   - The catch-all deny remains as a final backstop.
     *
     *   Rules are NOT filters: collectionGroup membership discovery must be
     *   constrained by the signed-in uid or emailNormalized. Project data
     *   queries must still be scoped by projectId.
     *
     * See:
     *   /docs/STAM-Firestore-Project-Membership-Gate-Guide
     *   /docs/STAM-Firebase-Auth-Firestore-Rules-Baseline-Guide
     *   /docs/STAM-Auth-Project-Member-Data-Structure-Guide
     *   /docs/STAM-Phase-1-Productization-Scope
     */

    // ── Auth helpers ───────────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }
    function uid() {
      return request.auth.uid;
    }

    // ── Membership helpers ────────────────────────────────────────
    // The canonical active-membership indicator is a document at
    //   projects/{projectId}/members/{uid}
    // with status == "active". The doc id equals the Firebase Auth
    // uid — never rely on email alone for project data authorization.
    function memberPath(projectId) {
      return /databases/$(database)/documents/projects/$(projectId)/members/$(uid());
    }
    function hasMemberDoc(projectId) {
      return signedIn() && exists(memberPath(projectId));
    }
    function memberData(projectId) {
      return get(memberPath(projectId)).data;
    }
    function isActiveProjectMember(projectId) {
      return hasMemberDoc(projectId)
          && memberData(projectId).userId == uid()
          && memberData(projectId).projectId == projectId
          && memberData(projectId).status == "active";
    }
    function memberRole(projectId) {
      return memberData(projectId).role;
    }
    function isRequirementWriter(projectId) {
      return isActiveProjectMember(projectId) && (
        memberRole(projectId) == "owner" ||
        memberRole(projectId) == "admin" ||
        memberRole(projectId) == "editor"
      );
    }
    function isFunctionalSpecWriter(projectId) {
      return isRequirementWriter(projectId);
    }
    function canReadProject(projectId) {
      return isActiveProjectMember(projectId);
    }
    function authEmailNormalized() {
      return request.auth.token.email.lower();
    }
    function isOwnMembershipRecord() {
      return signedIn() && (
        resource.data.userId == uid() ||
        resource.data.emailNormalized == authEmailNormalized()
      );
    }

    // ── Project create helpers (PR #357) ─────────────────────────
    function projectDocPath(projectId) {
      return /databases/$(database)/documents/projects/$(projectId);
    }
    function projectCreateKeys() {
      return [
        'projectId',
        'projectName',
        'name',
        'status',
        'tenantId',
        'ownerUid',
        'ownerEmail',
        'createdBy',
        'createdAt',
        'updatedAt',
        'lastOpenedAt',
      ];
    }
    function isValidProjectName(name) {
      return name is string
          && name.size() >= 2
          && name.size() <= 60;
    }
    function isValidProjectCreate(projectId) {
      let data = request.resource.data;
      return signedIn()
          && !exists(projectDocPath(projectId))
          && data.projectId == projectId
          && data.status == 'active'
          && data.ownerUid == uid()
          && data.createdBy == uid()
          && data.ownerEmail is string
          && data.ownerEmail == request.auth.token.email
          && data.tenantId is string
          && data.tenantId.size() >= 1
          && isValidProjectName(data.projectName)
          && isValidProjectName(data.name)
          && data.name == data.projectName
          && data.keys().hasOnly(projectCreateKeys())
          && data.createdAt == request.time
          && data.updatedAt == request.time
          && data.lastOpenedAt == request.time;
    }
    function ownerMemberCreateKeys() {
      return [
        'userId',
        'projectId',
        'projectName',
        'tenantId',
        'email',
        'emailNormalized',
        'displayName',
        'role',
        'status',
        'joinedAt',
        'createdAt',
        'updatedAt',
        'createdBy',
      ];
    }
    function isValidOwnerMemberCreate(projectId, memberUid) {
      let data = request.resource.data;
      let projectAfter = getAfter(projectDocPath(projectId)).data;
      return signedIn()
          && memberUid == uid()
          && !exists(memberPath(projectId))
          && data.userId == uid()
          && data.projectId == projectId
          && data.role == 'owner'
          && data.status == 'active'
          && data.createdBy == uid()
          && data.email is string
          && data.emailNormalized is string
          && data.emailNormalized == data.email.lower()
          && data.email == request.auth.token.email
          && data.displayName is string
          && data.tenantId == projectAfter.tenantId
          && data.projectName == projectAfter.projectName
          && isValidProjectName(data.projectName)
          && data.keys().hasOnly(ownerMemberCreateKeys())
          && data.joinedAt == request.time
          && data.createdAt == request.time
          && data.updatedAt == request.time
          && projectAfter.projectId == projectId
          && projectAfter.ownerUid == uid()
          && projectAfter.createdBy == uid();
    }

    // ── Requirements write helpers (PR #358) ──────────────────────
    function isValidRequirementTitle(title) {
      return title is string
          && title.size() >= 2
          && title.size() <= 120;
    }
    function isValidRequirementStatus(status) {
      return status is string && (
        status == 'draft' ||
        status == 'active' ||
        status == 'review' ||
        status == 'approved' ||
        status == 'archived'
      );
    }
    function isValidRequirementPriority(priority) {
      return priority is string && (
        priority == 'low' ||
        priority == 'normal' ||
        priority == 'high' ||
        priority == 'critical'
      );
    }
    function isValidRequirementVisibility(visibility) {
      return visibility is string && (
        visibility == 'project' ||
        visibility == 'internal' ||
        visibility == 'customer' ||
        visibility == 'private'
      );
    }
    function requirementWriteKeys() {
      return [
        'id',
        'projectId',
        'code',
        'title',
        'description',
        'background',
        'status',
        'priority',
        'ownerUid',
        'ownerName',
        'createdAt',
        'createdBy',
        'updatedAt',
        'updatedBy',
        'deletedAt',
        'deletedBy',
        'isDeleted',
        'version',
        'sortOrder',
        'tags',
        'visibility',
        'reviewStatus',
        'approvalStatus',
      ];
    }
    function isValidRequirementsCounterWrite() {
      let data = request.resource.data;
      return data.keys().hasOnly(['lastNumber'])
          && data.lastNumber is int
          && data.lastNumber >= 1
          && (
            resource == null && data.lastNumber == 1
            || resource != null
                && resource.data.keys().hasOnly(['lastNumber'])
                && resource.data.lastNumber is int
                && data.lastNumber == resource.data.lastNumber + 1
          );
    }
    function isValidFunctionalSpecificationsCounterWrite() {
      return isValidRequirementsCounterWrite();
    }
    function requirementCreateCoreValid(data, requirementId) {
      return data.id == requirementId
          && data.projectId is string
          && isValidRequirementTitle(data.title)
          && isValidRequirementStatus(data.status)
          && isValidRequirementPriority(data.priority)
          && data.createdBy is string
          && data.updatedBy is string
          && data.isDeleted == false
          && data.deletedAt == null
          && data.deletedBy == null
          && data.version is int
          && data.version == 1
          && data.keys().hasOnly(requirementWriteKeys())
          && (!data.keys().hasAny(['code']) || data.code is string)
          && (!data.keys().hasAny(['description']) || data.description is string)
          && (!data.keys().hasAny(['background']) || data.background is string)
          && (!data.keys().hasAny(['ownerUid']) || data.ownerUid is string)
          && (!data.keys().hasAny(['ownerName']) || data.ownerName is string)
          && (!data.keys().hasAny(['sortOrder']) || data.sortOrder is int)
          && (!data.keys().hasAny(['tags']) || data.tags is list)
          && (!data.keys().hasAny(['visibility']) || isValidRequirementVisibility(data.visibility))
          && (!data.keys().hasAny(['reviewStatus']) || data.reviewStatus is string)
          && (!data.keys().hasAny(['approvalStatus']) || data.approvalStatus is string);
    }
    function isValidRequirementCreate(projectId, requirementId) {
      let data = request.resource.data;
      return isRequirementWriter(projectId)
          && data.projectId == projectId
          && requirementCreateCoreValid(data, requirementId)
          && data.createdBy == uid()
          && data.updatedBy == uid()
          && data.createdAt == request.time
          && data.updatedAt == request.time;
    }
    function isValidRequirementUpdate(projectId, requirementId) {
      let data = request.resource.data;
      let prev = resource.data;
      return isRequirementWriter(projectId)
          && data.id == requirementId
          && data.projectId == projectId
          && data.projectId == prev.projectId
          && data.id == prev.id
          && isValidRequirementTitle(data.title)
          && isValidRequirementStatus(data.status)
          && isValidRequirementPriority(data.priority)
          && data.createdBy == prev.createdBy
          && data.createdAt == prev.createdAt
          && data.isDeleted == prev.isDeleted
          && data.deletedAt == prev.deletedAt
          && data.deletedBy == prev.deletedBy
          && data.version is int
          && data.version == prev.version + 1
          && data.keys().hasOnly(requirementWriteKeys())
          && (!data.keys().hasAny(['code']) || data.code is string)
          && (!data.keys().hasAny(['description']) || data.description is string)
          && (!data.keys().hasAny(['background']) || data.background is string)
          && (!data.keys().hasAny(['ownerUid']) || data.ownerUid is string)
          && (!data.keys().hasAny(['ownerName']) || data.ownerName is string)
          && (!data.keys().hasAny(['sortOrder']) || data.sortOrder is int)
          && (!data.keys().hasAny(['tags']) || data.tags is list)
          && (!data.keys().hasAny(['visibility']) || isValidRequirementVisibility(data.visibility))
          && (!data.keys().hasAny(['reviewStatus']) || data.reviewStatus is string)
          && (!data.keys().hasAny(['approvalStatus']) || data.approvalStatus is string)
          && data.updatedBy == uid()
          && data.updatedAt == request.time;
    }

    // ── Functional specifications write helpers (FS-1) ───────────
    function isValidFunctionalSpecTitle(title) {
      return title is string
          && title.size() >= 2
          && title.size() <= 120;
    }
    function isValidFunctionalSpecStatus(status) {
      return status is string && (
        status == 'draft' ||
        status == 'review' ||
        status == 'done' ||
        status == 'approved' ||
        status == 'hold'
      );
    }
    function isValidFunctionalSpecPriority(priority) {
      return priority is string && (
        priority == 'high' ||
        priority == 'mid' ||
        priority == 'low'
      );
    }
    function isValidFunctionalSpecFunctionType(functionType) {
      return functionType is string && (
        functionType == 'view' ||
        functionType == 'create' ||
        functionType == 'update' ||
        functionType == 'delete' ||
        functionType == 'approve' ||
        functionType == 'notify' ||
        functionType == 'export' ||
        functionType == 'integrate'
      );
    }
    function functionalSpecWriteKeys() {
      return [
        'id',
        'projectId',
        'code',
        'title',
        'description',
        'status',
        'priority',
        'functionType',
        'ownerUid',
        'ownerName',
        'requirementId',
        'requirementCode',
        'requirementTitle',
        'linkedScreen',
        'inputSpec',
        'businessRule',
        'exceptionRule',
        'apiRef',
        'note',
        'reviewStatus',
        'createdAt',
        'createdBy',
        'updatedAt',
        'updatedBy',
        'deletedAt',
        'deletedBy',
        'isDeleted',
        'version',
      ];
    }
    function functionalSpecCreateCoreValid(data, functionalSpecId) {
      return data.id == functionalSpecId
          && data.projectId is string
          && isValidFunctionalSpecTitle(data.title)
          && isValidFunctionalSpecStatus(data.status)
          && isValidFunctionalSpecPriority(data.priority)
          && data.createdBy is string
          && data.updatedBy is string
          && data.isDeleted == false
          && data.deletedAt == null
          && data.deletedBy == null
          && data.version is int
          && data.version == 1
          && data.keys().hasOnly(functionalSpecWriteKeys())
          && (!data.keys().hasAny(['code']) || data.code is string)
          && (!data.keys().hasAny(['description']) || data.description is string)
          && (!data.keys().hasAny(['functionType']) || isValidFunctionalSpecFunctionType(data.functionType))
          && (!data.keys().hasAny(['ownerUid']) || data.ownerUid is string)
          && (!data.keys().hasAny(['ownerName']) || data.ownerName is string)
          && (!data.keys().hasAny(['requirementId']) || data.requirementId is string)
          && (!data.keys().hasAny(['requirementCode']) || data.requirementCode is string)
          && (!data.keys().hasAny(['requirementTitle']) || data.requirementTitle is string)
          && (!data.keys().hasAny(['linkedScreen']) || data.linkedScreen is string)
          && (!data.keys().hasAny(['inputSpec']) || data.inputSpec is string)
          && (!data.keys().hasAny(['businessRule']) || data.businessRule is string)
          && (!data.keys().hasAny(['exceptionRule']) || data.exceptionRule is string)
          && (!data.keys().hasAny(['apiRef']) || data.apiRef is string)
          && (!data.keys().hasAny(['note']) || data.note is string)
          && (!data.keys().hasAny(['reviewStatus']) || data.reviewStatus is string);
    }
    function isValidFunctionalSpecCreate(projectId, functionalSpecId) {
      let data = request.resource.data;
      return isFunctionalSpecWriter(projectId)
          && data.projectId == projectId
          && functionalSpecCreateCoreValid(data, functionalSpecId)
          && data.createdBy == uid()
          && data.updatedBy == uid()
          && data.createdAt == request.time
          && data.updatedAt == request.time;
    }
    function isValidFunctionalSpecUpdate(projectId, functionalSpecId) {
      let data = request.resource.data;
      let prev = resource.data;
      return isFunctionalSpecWriter(projectId)
          && data.id == functionalSpecId
          && data.projectId == projectId
          && data.projectId == prev.projectId
          && data.id == prev.id
          && isValidFunctionalSpecTitle(data.title)
          && isValidFunctionalSpecStatus(data.status)
          && isValidFunctionalSpecPriority(data.priority)
          && data.createdBy == prev.createdBy
          && data.createdAt == prev.createdAt
          && data.isDeleted == prev.isDeleted
          && data.deletedAt == prev.deletedAt
          && data.deletedBy == prev.deletedBy
          && data.version is int
          && data.version == prev.version + 1
          && data.keys().hasOnly(functionalSpecWriteKeys())
          && (!data.keys().hasAny(['code']) || data.code is string)
          && (!data.keys().hasAny(['description']) || data.description is string)
          && (!data.keys().hasAny(['functionType']) || isValidFunctionalSpecFunctionType(data.functionType))
          && (!data.keys().hasAny(['ownerUid']) || data.ownerUid is string)
          && (!data.keys().hasAny(['ownerName']) || data.ownerName is string)
          && (!data.keys().hasAny(['requirementId']) || data.requirementId is string)
          && (!data.keys().hasAny(['requirementCode']) || data.requirementCode is string)
          && (!data.keys().hasAny(['requirementTitle']) || data.requirementTitle is string)
          && (!data.keys().hasAny(['linkedScreen']) || data.linkedScreen is string)
          && (!data.keys().hasAny(['inputSpec']) || data.inputSpec is string)
          && (!data.keys().hasAny(['businessRule']) || data.businessRule is string)
          && (!data.keys().hasAny(['exceptionRule']) || data.exceptionRule is string)
          && (!data.keys().hasAny(['apiRef']) || data.apiRef is string)
          && (!data.keys().hasAny(['note']) || data.note is string)
          && (!data.keys().hasAny(['reviewStatus']) || data.reviewStatus is string)
          && data.updatedBy == uid()
          && data.updatedAt == request.time;
    }

    // ── WBS write helpers (WBS-1) ─────────────────────────────────────
    function projectMemberPath(projectId, memberUid) {
      return /databases/$(database)/documents/projects/$(projectId)/members/$(memberUid);
    }
    function isValidProjectMemberSnapshot(projectId, memberUid, memberName) {
      return memberUid is string
          && memberUid.size() > 0
          && memberName is string
          && memberName.size() > 0
          && exists(projectMemberPath(projectId, memberUid))
          && get(projectMemberPath(projectId, memberUid)).data.userId == memberUid
          && get(projectMemberPath(projectId, memberUid)).data.projectId == projectId
          && get(projectMemberPath(projectId, memberUid)).data.status == "active"
          && get(projectMemberPath(projectId, memberUid)).data.displayName == memberName;
    }
    function isWbsWriter(projectId) {
      return isRequirementWriter(projectId);
    }
    function isValidWbsTitle(title) {
      return title is string
          && title.size() >= 2
          && title.size() <= 120;
    }
    function isValidWbsPhase(phase) {
      return phase is string && (
        phase == '착수' ||
        phase == '분석' ||
        phase == '설계' ||
        phase == '구현' ||
        phase == '검수' ||
        phase == '오픈' ||
        phase == '완료'
      );
    }
    function isValidWbsStatus(status) {
      return status is string && (
        status == 'wait' ||
        status == 'in_progress' ||
        status == 'delayed' ||
        status == 'done' ||
        status == 'hold'
      );
    }
    function isValidWbsPriority(priority) {
      return priority is string && (
        priority == 'high' ||
        priority == 'mid' ||
        priority == 'low'
      );
    }
    function isValidWbsCode(code) {
      return code is string
          && code.size() > 0
          && code.matches('^WBS-[0-9]{3,}$');
    }
    function isValidWbsDate(date) {
      return date is string
          && date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
    }
    function isValidWbsProgress(status, progress) {
      return progress is int
          && progress >= 0
          && progress <= 100
          && (
            (status == 'done' && progress == 100)
            || (status != 'done' && progress < 100)
          );
    }
    function isValidWbsOwner(projectId, data) {
      return data.keys().hasAll(['ownerId', 'ownerName'])
          && data.ownerId is string
          && data.ownerId.size() > 0
          && data.ownerName is string
          && data.ownerName.size() > 0
          && isValidProjectMemberSnapshot(projectId, data.ownerId, data.ownerName);
    }
    function isValidWbsReviewer(projectId, data) {
      let hasReviewerId = data.keys().hasAny(['reviewerId']);
      let hasReviewerName = data.keys().hasAny(['reviewerName']);
      return (!hasReviewerId && !hasReviewerName)
          || (hasReviewerId && hasReviewerName
              && data.reviewerId is string
              && data.reviewerId.size() > 0
              && data.reviewerName is string
              && data.reviewerName.size() > 0
              && isValidProjectMemberSnapshot(projectId, data.reviewerId, data.reviewerName));
    }
    function isValidWbsRequirementLink(data) {
      let hasId = data.keys().hasAny(['requirementId']);
      let hasCode = data.keys().hasAny(['requirementCode']);
      let hasTitle = data.keys().hasAny(['requirementTitle']);
      return (!hasId && !hasCode && !hasTitle)
          || (hasId && hasCode && hasTitle
              && data.requirementId is string
              && data.requirementId.size() > 0
              && data.requirementCode is string
              && data.requirementCode.matches('^REQ_[0-9]{3,}$')
              && data.requirementTitle is string
              && data.requirementTitle.size() > 0);
    }
    function isValidWbsFunctionalSpecLink(data) {
      let hasId = data.keys().hasAny(['functionalSpecId']);
      let hasCode = data.keys().hasAny(['functionalSpecCode']);
      let hasTitle = data.keys().hasAny(['functionalSpecTitle']);
      return (!hasId && !hasCode && !hasTitle)
          || (hasId && hasCode && hasTitle
              && data.functionalSpecId is string
              && data.functionalSpecId.size() > 0
              && data.functionalSpecCode is string
              && data.functionalSpecCode.matches('^FN_[0-9]{3,}$')
              && data.functionalSpecTitle is string
              && data.functionalSpecTitle.size() > 0);
    }
    function wbsWriteKeys() {
      return [
        'id',
        'projectId',
        'code',
        'title',
        'phase',
        'businessArea',
        'functionGroup',
        'screenPath',
        'status',
        'priority',
        'ownerId',
        'ownerName',
        'reviewerId',
        'reviewerName',
        'startDate',
        'endDate',
        'plannedEffort',
        'actualEffort',
        'progress',
        'description',
        'requirementId',
        'requirementCode',
        'requirementTitle',
        'functionalSpecId',
        'functionalSpecCode',
        'functionalSpecTitle',
        'createdAt',
        'createdBy',
        'updatedAt',
        'updatedBy',
        'deletedAt',
        'deletedBy',
        'isDeleted',
        'version',
      ];
    }
    function wbsRequiredKeys() {
      return [
        'id',
        'projectId',
        'code',
        'title',
        'phase',
        'functionGroup',
        'status',
        'priority',
        'ownerId',
        'ownerName',
        'startDate',
        'endDate',
        'progress',
        'createdAt',
        'createdBy',
        'updatedAt',
        'updatedBy',
        'deletedAt',
        'deletedBy',
        'isDeleted',
        'version',
      ];
    }
    function isValidWbsItemsCounterWrite() {
      return isValidRequirementsCounterWrite();
    }
    function wbsFieldValidation(projectId, data) {
      return isValidWbsTitle(data.title)
          && isValidWbsPhase(data.phase)
          && isValidWbsStatus(data.status)
          && isValidWbsPriority(data.priority)
          && isValidWbsCode(data.code)
          && data.functionGroup is string
          && data.functionGroup.size() > 0
          && data.functionGroup.size() <= 120
          && isValidWbsDate(data.startDate)
          && isValidWbsDate(data.endDate)
          && data.endDate >= data.startDate
          && isValidWbsProgress(data.status, data.progress)
          && isValidWbsOwner(projectId, data)
          && isValidWbsReviewer(projectId, data)
          && isValidWbsRequirementLink(data)
          && isValidWbsFunctionalSpecLink(data)
          && (!data.keys().hasAny(['businessArea']) || (
            data.businessArea is string
            && data.businessArea.size() > 0
            && data.businessArea.size() <= 120
          ))
          && (!data.keys().hasAny(['screenPath']) || (
            data.screenPath is string
            && data.screenPath.size() <= 500
          ))
          && (!data.keys().hasAny(['description']) || (
            data.description is string
            && data.description.size() <= 4000
          ))
          && (!data.keys().hasAny(['plannedEffort']) || (
            data.plannedEffort is number
            && data.plannedEffort >= 0
          ))
          && (!data.keys().hasAny(['actualEffort']) || (
            data.actualEffort is number
            && data.actualEffort >= 0
          ));
    }
    function wbsCreateCoreValid(projectId, data, wbsItemId) {
      return data.id == wbsItemId
          && data.projectId == projectId
          && data.id is string
          && data.projectId is string
          && data.keys().hasAll(wbsRequiredKeys())
          && data.keys().hasOnly(wbsWriteKeys())
          && wbsFieldValidation(projectId, data)
          && data.createdBy is string
          && data.updatedBy is string
          && data.isDeleted == false
          && data.deletedAt == null
          && data.deletedBy == null
          && data.version is int
          && data.version == 1;
    }
    function isValidWbsCreate(projectId, wbsItemId) {
      let data = request.resource.data;
      return isWbsWriter(projectId)
          && wbsCreateCoreValid(projectId, data, wbsItemId)
          && data.createdBy == uid()
          && data.updatedBy == uid()
          && data.createdAt == request.time
          && data.updatedAt == request.time;
    }
    function isValidWbsUpdate(projectId, wbsItemId) {
      let data = request.resource.data;
      let prev = resource.data;
      return isWbsWriter(projectId)
          && data.id == wbsItemId
          && data.projectId == projectId
          && data.id == prev.id
          && data.projectId == prev.projectId
          && data.code == prev.code
          && data.createdAt == prev.createdAt
          && data.createdBy == prev.createdBy
          && data.isDeleted == prev.isDeleted
          && data.deletedAt == prev.deletedAt
          && data.deletedBy == prev.deletedBy
          && data.keys().hasAll(wbsRequiredKeys())
          && data.keys().hasOnly(wbsWriteKeys())
          && wbsFieldValidation(projectId, data)
          && data.version is int
          && data.version == prev.version + 1
          && data.updatedBy == uid()
          && data.updatedAt == request.time;
    }

    // ── ScreenSpec write helpers (ScreenSpec-1) ───────────────────────
    function isScreenSpecWriter(projectId) {
      return isRequirementWriter(projectId);
    }
    function isValidScreenSpecTitle(title) {
      return title is string
          && title.size() >= 2
          && title.size() <= 120;
    }
    function isValidScreenSpecCode(code) {
      return code is string
          && code.size() > 0
          && code.matches('^SCR-[0-9]{3,}$');
    }
    function isValidScreenSpecType(screenType) {
      return screenType is string && (
        screenType == 'list' ||
        screenType == 'detail' ||
        screenType == 'form' ||
        screenType == 'popup' ||
        screenType == 'admin' ||
        screenType == 'main' ||
        screenType == 'result' ||
        screenType == 'other'
      );
    }
    function isValidScreenSpecWriteStatus(writeStatus) {
      return writeStatus is string && (
        writeStatus == 'writing' ||
        writeStatus == 'complete'
      );
    }
    function isValidScreenSpecReviewStatus(reviewStatus) {
      return reviewStatus is string && (
        reviewStatus == 'none' ||
        reviewStatus == 'pending' ||
        reviewStatus == 'done'
      );
    }
    function isValidScreenSpecApprovalStatus(approvalStatus) {
      return approvalStatus is string && (
        approvalStatus == 'none' ||
        approvalStatus == 'approved' ||
        approvalStatus == 'rejected'
      );
    }
    function isValidScreenSpecOwner(projectId, data) {
      return data.keys().hasAll(['ownerId', 'ownerName'])
          && data.ownerId is string
          && data.ownerId.size() > 0
          && data.ownerName is string
          && data.ownerName.size() > 0
          && isValidProjectMemberSnapshot(projectId, data.ownerId, data.ownerName);
    }
    function isValidScreenSpecRequirementLink(data) {
      let hasId = data.keys().hasAny(['requirementId']);
      let hasCode = data.keys().hasAny(['requirementCode']);
      let hasTitle = data.keys().hasAny(['requirementTitle']);
      return (!hasId && !hasCode && !hasTitle)
          || (hasId && hasCode && hasTitle
              && data.requirementId is string
              && data.requirementId.size() > 0
              && data.requirementCode is string
              && data.requirementCode.matches('^REQ_[0-9]{3,}$')
              && data.requirementTitle is string
              && data.requirementTitle.size() > 0);
    }
    function isValidScreenSpecFunctionalSpecLink(data) {
      let hasId = data.keys().hasAny(['functionalSpecId']);
      let hasCode = data.keys().hasAny(['functionalSpecCode']);
      let hasTitle = data.keys().hasAny(['functionalSpecTitle']);
      return (!hasId && !hasCode && !hasTitle)
          || (hasId && hasCode && hasTitle
              && data.functionalSpecId is string
              && data.functionalSpecId.size() > 0
              && data.functionalSpecCode is string
              && data.functionalSpecCode.matches('^FN_[0-9]{3,}$')
              && data.functionalSpecTitle is string
              && data.functionalSpecTitle.size() > 0);
    }
    function isValidScreenSpecWbsItemLink(data) {
      let hasId = data.keys().hasAny(['wbsItemId']);
      let hasCode = data.keys().hasAny(['wbsItemCode']);
      let hasTitle = data.keys().hasAny(['wbsItemTitle']);
      return (!hasId && !hasCode && !hasTitle)
          || (hasId && hasCode && hasTitle
              && data.wbsItemId is string
              && data.wbsItemId.size() > 0
              && data.wbsItemCode is string
              && data.wbsItemCode.matches('^WBS-[0-9]{3,}$')
              && data.wbsItemTitle is string
              && data.wbsItemTitle.size() > 0);
    }
    function isValidScreenSpecMenuScreenLink(data) {
      let hasId = data.keys().hasAny(['menuScreenId']);
      let hasCode = data.keys().hasAny(['menuScreenCode']);
      let hasTitle = data.keys().hasAny(['menuScreenTitle']);
      return (!hasId && !hasCode && !hasTitle)
          || (hasId && hasCode && hasTitle
              && data.menuScreenId is string
              && data.menuScreenId.size() > 0
              && data.menuScreenCode is string
              && data.menuScreenCode.size() > 0
              && data.menuScreenTitle is string
              && data.menuScreenTitle.size() > 0);
    }
    function screenSpecWriteKeys() {
      return [
        'id',
        'projectId',
        'code',
        'title',
        'screenType',
        'writeStatus',
        'reviewStatus',
        'approvalStatus',
        'ownerId',
        'ownerName',
        'templateId',
        'routePath',
        'menuPath',
        'description',
        'imageCount',
        'annotationCount',
        'requirementId',
        'requirementCode',
        'requirementTitle',
        'functionalSpecId',
        'functionalSpecCode',
        'functionalSpecTitle',
        'wbsItemId',
        'wbsItemCode',
        'wbsItemTitle',
        'menuScreenId',
        'menuScreenCode',
        'menuScreenTitle',
        'createdAt',
        'createdBy',
        'updatedAt',
        'updatedBy',
        'deletedAt',
        'deletedBy',
        'isDeleted',
        'version',
      ];
    }
    function screenSpecRequiredKeys() {
      return [
        'id',
        'projectId',
        'code',
        'title',
        'screenType',
        'writeStatus',
        'reviewStatus',
        'approvalStatus',
        'ownerId',
        'ownerName',
        'createdAt',
        'createdBy',
        'updatedAt',
        'updatedBy',
        'deletedAt',
        'deletedBy',
        'isDeleted',
        'version',
      ];
    }
    function isValidScreenSpecsCounterWrite() {
      return isValidRequirementsCounterWrite();
    }
    function screenSpecFieldValidation(projectId, data) {
      return isValidScreenSpecTitle(data.title)
          && isValidScreenSpecCode(data.code)
          && isValidScreenSpecType(data.screenType)
          && isValidScreenSpecWriteStatus(data.writeStatus)
          && isValidScreenSpecReviewStatus(data.reviewStatus)
          && isValidScreenSpecApprovalStatus(data.approvalStatus)
          && isValidScreenSpecOwner(projectId, data)
          && isValidScreenSpecRequirementLink(data)
          && isValidScreenSpecFunctionalSpecLink(data)
          && isValidScreenSpecWbsItemLink(data)
          && isValidScreenSpecMenuScreenLink(data)
          && (!data.keys().hasAny(['templateId']) || (
            data.templateId is string
            && data.templateId.size() <= 120
          ))
          && (!data.keys().hasAny(['routePath']) || (
            data.routePath is string
            && data.routePath.size() <= 500
          ))
          && (!data.keys().hasAny(['menuPath']) || (
            data.menuPath is string
            && data.menuPath.size() <= 500
          ))
          && (!data.keys().hasAny(['description']) || (
            data.description is string
            && data.description.size() <= 4000
          ))
          && (!data.keys().hasAny(['imageCount']) || (
            data.imageCount is int
            && data.imageCount >= 0
          ))
          && (!data.keys().hasAny(['annotationCount']) || (
            data.annotationCount is int
            && data.annotationCount >= 0
          ));
    }
    function screenSpecCreateCoreValid(projectId, data, screenSpecId) {
      return data.id == screenSpecId
          && data.projectId == projectId
          && data.id is string
          && data.projectId is string
          && data.keys().hasAll(screenSpecRequiredKeys())
          && data.keys().hasOnly(screenSpecWriteKeys())
          && screenSpecFieldValidation(projectId, data)
          && data.createdBy is string
          && data.updatedBy is string
          && data.isDeleted == false
          && data.deletedAt == null
          && data.deletedBy == null
          && data.version is int
          && data.version == 1;
    }
    function isValidScreenSpecCreate(projectId, screenSpecId) {
      let data = request.resource.data;
      return isScreenSpecWriter(projectId)
          && screenSpecCreateCoreValid(projectId, data, screenSpecId)
          && data.createdBy == uid()
          && data.updatedBy == uid()
          && data.createdAt == request.time
          && data.updatedAt == request.time;
    }
    function isValidScreenSpecUpdate(projectId, screenSpecId) {
      let data = request.resource.data;
      let prev = resource.data;
      return isScreenSpecWriter(projectId)
          && data.id == screenSpecId
          && data.projectId == projectId
          && data.id == prev.id
          && data.projectId == prev.projectId
          && data.code == prev.code
          && data.createdAt == prev.createdAt
          && data.createdBy == prev.createdBy
          && data.isDeleted == prev.isDeleted
          && data.deletedAt == prev.deletedAt
          && data.deletedBy == prev.deletedBy
          && data.keys().hasAll(screenSpecRequiredKeys())
          && data.keys().hasOnly(screenSpecWriteKeys())
          && screenSpecFieldValidation(projectId, data)
          && data.version is int
          && data.version == prev.version + 1
          && data.updatedBy == uid()
          && data.updatedAt == request.time;
    }

    // ── users/{uid} bootstrap helpers (PR #355) ───────────────────
    // Path variable userId must be passed into helpers explicitly.
    function userBootstrapKeys() {
      return [
        'userId',
        'email',
        'emailNormalized',
        'displayName',
        'photoURL',
        'provider',
        'status',
        'createdAt',
        'updatedAt',
        'lastLoginAt',
      ];
    }
    function isValidUserBootstrapCreate(userId) {
      let data = request.resource.data;
      return signedIn()
          && userId == uid()
          && data.userId == uid()
          && data.provider == 'google'
          && data.status == 'active'
          && data.email is string
          && data.emailNormalized is string
          && data.displayName is string
          && data.photoURL is string
          && data.emailNormalized == data.email.lower()
          && data.keys().hasOnly(userBootstrapKeys())
          && data.createdAt == request.time
          && data.updatedAt == request.time
          && data.lastLoginAt == request.time;
    }
    function isValidUserBootstrapUpdate(userId) {
      let data = request.resource.data;
      let prev = resource.data;
      return signedIn()
          && userId == uid()
          && data.userId == prev.userId
          && data.userId == uid()
          && data.provider == prev.provider
          && data.status == prev.status
          && data.createdAt == prev.createdAt
          && data.email is string
          && data.emailNormalized is string
          && data.displayName is string
          && data.photoURL is string
          && data.emailNormalized == data.email.lower()
          && data.updatedAt == request.time
          && data.lastLoginAt == request.time
          && data.diff(prev).affectedKeys().hasOnly([
            'email',
            'emailNormalized',
            'displayName',
            'photoURL',
            'updatedAt',
            'lastLoginAt',
          ]);
    }

    // ── users/{userId} ────────────────────────────────────────────
    // PR #355: signed-in user may bootstrap their own users/{uid} doc.
    // Self-read only. No delete. status/provider/createdAt are immutable
    // from the client on update.
    match /users/{userId} {
      allow read: if signedIn() && userId == uid();
      allow create: if isValidUserBootstrapCreate(userId);
      allow update: if isValidUserBootstrapUpdate(userId);
      allow delete: if false;
    }

    // ── tenants/{tenantId} ────────────────────────────────────────
    // tenant management UI is deferred. Rules stay fully closed so
    // no client can enumerate or read the tenants collection yet.
    match /tenants/{tenantId} {
      allow read, write: if false;
    }

    // ── projects/{projectId}/** ───────────────────────────────────
    // Every read on a project or its subcollections requires an
    // active member document under projects/{projectId}/members/{uid}.
    // Unopened artifact subcollections remain write-closed; opened collections
    // (requirements, functionalSpecifications, wbsItems, screenSpecs) use role-scoped rules.
    match /projects/{projectId} {
      allow get, list: if canReadProject(projectId);
      allow create: if isValidProjectCreate(projectId);
      allow update, delete: if false;

      match /members/{memberUid} {
        allow get: if signedIn() && (
          memberUid == uid() ||
          canReadProject(projectId)
        );
        allow list: if signedIn() && (
          isOwnMembershipRecord() ||
          canReadProject(projectId)
        );
        allow create: if isValidOwnerMemberCreate(projectId, memberUid);
        allow update, delete: if false;
      }

      match /requirements/{requirementId} {
        allow get, list: if canReadProject(projectId);
        allow create: if isValidRequirementCreate(projectId, requirementId);
        allow update: if isValidRequirementUpdate(projectId, requirementId);
        allow delete: if false;
      }

      match /functionalSpecifications/{functionalSpecId} {
        allow get, list: if canReadProject(projectId);
        allow create: if isValidFunctionalSpecCreate(projectId, functionalSpecId);
        allow update: if isValidFunctionalSpecUpdate(projectId, functionalSpecId);
        allow delete: if false;
      }

      match /counters/{counterId} {
        allow get, list: if canReadProject(projectId);
        allow create, update: if
            (
              counterId == 'requirements'
              && isRequirementWriter(projectId)
              && isValidRequirementsCounterWrite()
            )
            || (
              counterId == 'functionalSpecifications'
              && isFunctionalSpecWriter(projectId)
              && isValidFunctionalSpecificationsCounterWrite()
            )
            || (
              counterId == 'wbsItems'
              && isWbsWriter(projectId)
              && isValidWbsItemsCounterWrite()
            )
            || (
              counterId == 'screenSpecs'
              && isScreenSpecWriter(projectId)
              && isValidScreenSpecsCounterWrite()
            );
        allow delete: if false;
      }

      match /wbsItems/{wbsItemId} {
        allow get, list: if canReadProject(projectId);
        allow create: if isValidWbsCreate(projectId, wbsItemId);
        allow update: if isValidWbsUpdate(projectId, wbsItemId);
        allow delete: if false;
      }

      match /screenSpecs/{screenSpecId} {
        allow get, list: if canReadProject(projectId);
        allow create: if isValidScreenSpecCreate(projectId, screenSpecId);
        allow update: if isValidScreenSpecUpdate(projectId, screenSpecId);
        allow delete: if false;
      }

      match /screenFields/{fieldId} {
        allow get, list: if canReadProject(projectId);
        allow create, update, delete: if false;
      }

      match /screenActions/{actionId} {
        allow get, list: if canReadProject(projectId);
        allow create, update, delete: if false;
      }

      match /artifactLinks/{linkId} {
        allow get, list: if canReadProject(projectId);
        allow create, update, delete: if false;
      }
    }

    // ── collectionGroup('members') discovery ──────────────────────
    // Login routing does not know projectId yet. Allow signed-in users
    // to read only their own membership records through collectionGroup
    // queries constrained by userId or emailNormalized. Writes stay closed.
    match /{path=**}/members/{memberUid} {
      allow get, list: if isOwnMembershipRecord();
      allow create, update, delete: if false;
    }

    // ── Catch-all deny ────────────────────────────────────────────
    // Anything not explicitly matched above is denied. Never insert
    // a broader `allow read, write: if true` rule here — even for
    // debugging.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
