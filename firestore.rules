rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    /*
     * STAM Firestore Rules
     *
     * PR #297 (baseline):
     *   Deny-by-default only; helper `signedIn()` defined but unused.
     *
     * PR #298:
     *   Firestore layout finalized as `projects/{projectId}/**`
     *   subcollections. Active-project-member read gate is opened
     *   through `projects/{projectId}/members/{uid}`.
     *
     * PR #306:
     *   Authenticated users can discover only their own membership records
     *   through constrained `collectionGroup('members')` queries by uid or
     *   emailNormalized. This enables login-time routing before a projectId
     *   has been selected.
     *
     * PR #358:
     *   Requirements write opened for active members with role owner/admin/editor.
     *   Viewer remains read-only. Requirement delete stays closed.
     *
     * FS-1 (functionalSpecifications):
     *   Functional-spec write opened for active members with role owner/admin/editor.
     *   Viewer remains read-only. Functional-spec delete stays closed.
     *   Collection path: projects/{projectId}/functionalSpecifications/{functionalSpecId}
     *
     * FS-6A (functionalSpecifications counter):
     *   FN_### code counter at projects/{projectId}/counters/functionalSpecifications.
     *   Writer roles: owner/admin/editor only. Counter delete denied.
     *   Signed-in users may create or update only their own `users/{uid}`
     *   document for Google login bootstrap. Client cannot change `status`,
     *   `provider`, `userId`, or `createdAt` on update. Project writes remain
     *   closed.
     *
     *   - Rules gate is UID-based: allowed iff `projects/{projectId}/
     *     members/{request.auth.uid}` exists and .status == "active".
     *   - `email` / `emailNormalized` are stored on the member doc for
     *     invite / audit / display / future bootstrap.
     *   - Writes remain fully closed. Role-based writes
     *     (Owner / Admin / Editor / Viewer) land in a later PR.
     *   - The catch-all deny remains as a final backstop.
     *
     *   Rules are NOT filters: collectionGroup membership discovery must be
     *   constrained by the signed-in uid or emailNormalized. Project data
     *   queries must still be scoped by projectId.
     *
     * See:
     *   /docs/STAM-Firestore-Project-Membership-Gate-Guide
     *   /docs/STAM-Firebase-Auth-Firestore-Rules-Baseline-Guide
     *   /docs/STAM-Auth-Project-Member-Data-Structure-Guide
     *   /docs/STAM-Phase-1-Productization-Scope
     */

    // ── Auth helpers ───────────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }
    function uid() {
      return request.auth.uid;
    }

    // ── Membership helpers ────────────────────────────────────────
    // The canonical active-membership indicator is a document at
    //   projects/{projectId}/members/{uid}
    // with status == "active". The doc id equals the Firebase Auth
    // uid — never rely on email alone for project data authorization.
    function memberPath(projectId) {
      return /databases/$(database)/documents/projects/$(projectId)/members/$(uid());
    }
    function hasMemberDoc(projectId) {
      return signedIn() && exists(memberPath(projectId));
    }
    function memberData(projectId) {
      return get(memberPath(projectId)).data;
    }
    function isActiveProjectMember(projectId) {
      return hasMemberDoc(projectId)
          && memberData(projectId).userId == uid()
          && memberData(projectId).projectId == projectId
          && memberData(projectId).status == "active";
    }
    function memberRole(projectId) {
      return memberData(projectId).role;
    }
    function isRequirementWriter(projectId) {
      return isActiveProjectMember(projectId) && (
        memberRole(projectId) == "owner" ||
        memberRole(projectId) == "admin" ||
        memberRole(projectId) == "editor"
      );
    }
    function isFunctionalSpecWriter(projectId) {
      return isRequirementWriter(projectId);
    }
    function canReadProject(projectId) {
      return isActiveProjectMember(projectId);
    }
    function authEmailNormalized() {
      return request.auth.token.email.lower();
    }
    function isOwnMembershipRecord() {
      return signedIn() && (
        resource.data.userId == uid() ||
        resource.data.emailNormalized == authEmailNormalized()
      );
    }

    // ── Project create helpers (PR #357) ─────────────────────────
    function projectDocPath(projectId) {
      return /databases/$(database)/documents/projects/$(projectId);
    }
    function projectCreateKeys() {
      return [
        'projectId',
        'projectName',
        'name',
        'status',
        'tenantId',
        'ownerUid',
        'ownerEmail',
        'createdBy',
        'createdAt',
        'updatedAt',
        'lastOpenedAt',
      ];
    }
    function isValidProjectName(name) {
      return name is string
          && name.size() >= 2
          && name.size() <= 60;
    }
    function isValidProjectCreate(projectId) {
      let data = request.resource.data;
      return signedIn()
          && !exists(projectDocPath(projectId))
          && data.projectId == projectId
          && data.status == 'active'
          && data.ownerUid == uid()
          && data.createdBy == uid()
          && data.ownerEmail is string
          && data.ownerEmail == request.auth.token.email
          && data.tenantId is string
          && data.tenantId.size() >= 1
          && isValidProjectName(data.projectName)
          && isValidProjectName(data.name)
          && data.name == data.projectName
          && data.keys().hasOnly(projectCreateKeys())
          && data.createdAt == request.time
          && data.updatedAt == request.time
          && data.lastOpenedAt == request.time;
    }
    function ownerMemberCreateKeys() {
      return [
        'userId',
        'projectId',
        'projectName',
        'tenantId',
        'email',
        'emailNormalized',
        'displayName',
        'role',
        'status',
        'joinedAt',
        'createdAt',
        'updatedAt',
        'createdBy',
      ];
    }
    function isValidOwnerMemberCreate(projectId, memberUid) {
      let data = request.resource.data;
      let projectAfter = getAfter(projectDocPath(projectId)).data;
      return signedIn()
          && memberUid == uid()
          && !exists(memberPath(projectId))
          && data.userId == uid()
          && data.projectId == projectId
          && data.role == 'owner'
          && data.status == 'active'
          && data.createdBy == uid()
          && data.email is string
          && data.emailNormalized is string
          && data.emailNormalized == data.email.lower()
          && data.email == request.auth.token.email
          && data.displayName is string
          && data.tenantId == projectAfter.tenantId
          && data.projectName == projectAfter.projectName
          && isValidProjectName(data.projectName)
          && data.keys().hasOnly(ownerMemberCreateKeys())
          && data.joinedAt == request.time
          && data.createdAt == request.time
          && data.updatedAt == request.time
          && projectAfter.projectId == projectId
          && projectAfter.ownerUid == uid()
          && projectAfter.createdBy == uid();
    }

    // ── Requirements write helpers (PR #358) ──────────────────────
    function isValidRequirementTitle(title) {
      return title is string
          && title.size() >= 2
          && title.size() <= 120;
    }
    function isValidRequirementStatus(status) {
      return status is string && (
        status == 'draft' ||
        status == 'active' ||
        status == 'review' ||
        status == 'approved' ||
        status == 'archived'
      );
    }
    function isValidRequirementPriority(priority) {
      return priority is string && (
        priority == 'low' ||
        priority == 'normal' ||
        priority == 'high' ||
        priority == 'critical'
      );
    }
    function isValidRequirementVisibility(visibility) {
      return visibility is string && (
        visibility == 'project' ||
        visibility == 'internal' ||
        visibility == 'customer' ||
        visibility == 'private'
      );
    }
    function requirementWriteKeys() {
      return [
        'id',
        'projectId',
        'code',
        'title',
        'description',
        'background',
        'status',
        'priority',
        'ownerUid',
        'ownerName',
        'createdAt',
        'createdBy',
        'updatedAt',
        'updatedBy',
        'deletedAt',
        'deletedBy',
        'isDeleted',
        'version',
        'sortOrder',
        'tags',
        'visibility',
        'reviewStatus',
        'approvalStatus',
      ];
    }
    function isValidRequirementsCounterWrite() {
      let data = request.resource.data;
      return data.keys().hasOnly(['lastNumber'])
          && data.lastNumber is int
          && data.lastNumber >= 1
          && (
            resource == null && data.lastNumber == 1
            || resource != null
                && resource.data.keys().hasOnly(['lastNumber'])
                && resource.data.lastNumber is int
                && data.lastNumber == resource.data.lastNumber + 1
          );
    }
    function isValidFunctionalSpecificationsCounterWrite() {
      return isValidRequirementsCounterWrite();
    }
    function requirementCreateCoreValid(data, requirementId) {
      return data.id == requirementId
          && data.projectId is string
          && isValidRequirementTitle(data.title)
          && isValidRequirementStatus(data.status)
          && isValidRequirementPriority(data.priority)
          && data.createdBy is string
          && data.updatedBy is string
          && data.isDeleted == false
          && data.deletedAt == null
          && data.deletedBy == null
          && data.version is int
          && data.version == 1
          && data.keys().hasOnly(requirementWriteKeys())
          && (!data.keys().hasAny(['code']) || data.code is string)
          && (!data.keys().hasAny(['description']) || data.description is string)
          && (!data.keys().hasAny(['background']) || data.background is string)
          && (!data.keys().hasAny(['ownerUid']) || data.ownerUid is string)
          && (!data.keys().hasAny(['ownerName']) || data.ownerName is string)
          && (!data.keys().hasAny(['sortOrder']) || data.sortOrder is int)
          && (!data.keys().hasAny(['tags']) || data.tags is list)
          && (!data.keys().hasAny(['visibility']) || isValidRequirementVisibility(data.visibility))
          && (!data.keys().hasAny(['reviewStatus']) || data.reviewStatus is string)
          && (!data.keys().hasAny(['approvalStatus']) || data.approvalStatus is string);
    }
    function isValidRequirementCreate(projectId, requirementId) {
      let data = request.resource.data;
      return isRequirementWriter(projectId)
          && data.projectId == projectId
          && requirementCreateCoreValid(data, requirementId)
          && data.createdBy == uid()
          && data.updatedBy == uid()
          && data.createdAt == request.time
          && data.updatedAt == request.time;
    }
    function isValidRequirementUpdate(projectId, requirementId) {
      let data = request.resource.data;
      let prev = resource.data;
      return isRequirementWriter(projectId)
          && data.id == requirementId
          && data.projectId == projectId
          && data.projectId == prev.projectId
          && data.id == prev.id
          && isValidRequirementTitle(data.title)
          && isValidRequirementStatus(data.status)
          && isValidRequirementPriority(data.priority)
          && data.createdBy == prev.createdBy
          && data.createdAt == prev.createdAt
          && data.isDeleted == prev.isDeleted
          && data.deletedAt == prev.deletedAt
          && data.deletedBy == prev.deletedBy
          && data.version is int
          && data.version == prev.version + 1
          && data.keys().hasOnly(requirementWriteKeys())
          && (!data.keys().hasAny(['code']) || data.code is string)
          && (!data.keys().hasAny(['description']) || data.description is string)
          && (!data.keys().hasAny(['background']) || data.background is string)
          && (!data.keys().hasAny(['ownerUid']) || data.ownerUid is string)
          && (!data.keys().hasAny(['ownerName']) || data.ownerName is string)
          && (!data.keys().hasAny(['sortOrder']) || data.sortOrder is int)
          && (!data.keys().hasAny(['tags']) || data.tags is list)
          && (!data.keys().hasAny(['visibility']) || isValidRequirementVisibility(data.visibility))
          && (!data.keys().hasAny(['reviewStatus']) || data.reviewStatus is string)
          && (!data.keys().hasAny(['approvalStatus']) || data.approvalStatus is string)
          && data.updatedBy == uid()
          && data.updatedAt == request.time;
    }

    // ── Functional specifications write helpers (FS-1) ───────────
    function isValidFunctionalSpecTitle(title) {
      return title is string
          && title.size() >= 2
          && title.size() <= 120;
    }
    function isValidFunctionalSpecStatus(status) {
      return status is string && (
        status == 'draft' ||
        status == 'review' ||
        status == 'done' ||
        status == 'approved' ||
        status == 'hold'
      );
    }
    function isValidFunctionalSpecPriority(priority) {
      return priority is string && (
        priority == 'high' ||
        priority == 'mid' ||
        priority == 'low'
      );
    }
    function isValidFunctionalSpecFunctionType(functionType) {
      return functionType is string && (
        functionType == 'view' ||
        functionType == 'create' ||
        functionType == 'update' ||
        functionType == 'delete' ||
        functionType == 'approve' ||
        functionType == 'notify' ||
        functionType == 'export' ||
        functionType == 'integrate'
      );
    }
    function functionalSpecWriteKeys() {
      return [
        'id',
        'projectId',
        'code',
        'title',
        'description',
        'status',
        'priority',
        'functionType',
        'ownerUid',
        'ownerName',
        'requirementId',
        'requirementCode',
        'requirementTitle',
        'linkedScreen',
        'inputSpec',
        'businessRule',
        'exceptionRule',
        'apiRef',
        'note',
        'reviewStatus',
        'createdAt',
        'createdBy',
        'updatedAt',
        'updatedBy',
        'deletedAt',
        'deletedBy',
        'isDeleted',
        'version',
      ];
    }
    function functionalSpecCreateCoreValid(data, functionalSpecId) {
      return data.id == functionalSpecId
          && data.projectId is string
          && isValidFunctionalSpecTitle(data.title)
          && isValidFunctionalSpecStatus(data.status)
          && isValidFunctionalSpecPriority(data.priority)
          && data.createdBy is string
          && data.updatedBy is string
          && data.isDeleted == false
          && data.deletedAt == null
          && data.deletedBy == null
          && data.version is int
          && data.version == 1
          && data.keys().hasOnly(functionalSpecWriteKeys())
          && (!data.keys().hasAny(['code']) || data.code is string)
          && (!data.keys().hasAny(['description']) || data.description is string)
          && (!data.keys().hasAny(['functionType']) || isValidFunctionalSpecFunctionType(data.functionType))
          && (!data.keys().hasAny(['ownerUid']) || data.ownerUid is string)
          && (!data.keys().hasAny(['ownerName']) || data.ownerName is string)
          && (!data.keys().hasAny(['requirementId']) || data.requirementId is string)
          && (!data.keys().hasAny(['requirementCode']) || data.requirementCode is string)
          && (!data.keys().hasAny(['requirementTitle']) || data.requirementTitle is string)
          && (!data.keys().hasAny(['linkedScreen']) || data.linkedScreen is string)
          && (!data.keys().hasAny(['inputSpec']) || data.inputSpec is string)
          && (!data.keys().hasAny(['businessRule']) || data.businessRule is string)
          && (!data.keys().hasAny(['exceptionRule']) || data.exceptionRule is string)
          && (!data.keys().hasAny(['apiRef']) || data.apiRef is string)
          && (!data.keys().hasAny(['note']) || data.note is string)
          && (!data.keys().hasAny(['reviewStatus']) || data.reviewStatus is string);
    }
    function isValidFunctionalSpecCreate(projectId, functionalSpecId) {
      let data = request.resource.data;
      return isFunctionalSpecWriter(projectId)
          && data.projectId == projectId
          && functionalSpecCreateCoreValid(data, functionalSpecId)
          && data.createdBy == uid()
          && data.updatedBy == uid()
          && data.createdAt == request.time
          && data.updatedAt == request.time;
    }
    function isValidFunctionalSpecUpdate(projectId, functionalSpecId) {
      let data = request.resource.data;
      let prev = resource.data;
      return isFunctionalSpecWriter(projectId)
          && data.id == functionalSpecId
          && data.projectId == projectId
          && data.projectId == prev.projectId
          && data.id == prev.id
          && isValidFunctionalSpecTitle(data.title)
          && isValidFunctionalSpecStatus(data.status)
          && isValidFunctionalSpecPriority(data.priority)
          && data.createdBy == prev.createdBy
          && data.createdAt == prev.createdAt
          && data.isDeleted == prev.isDeleted
          && data.deletedAt == prev.deletedAt
          && data.deletedBy == prev.deletedBy
          && data.version is int
          && data.version == prev.version + 1
          && data.keys().hasOnly(functionalSpecWriteKeys())
          && (!data.keys().hasAny(['code']) || data.code is string)
          && (!data.keys().hasAny(['description']) || data.description is string)
          && (!data.keys().hasAny(['functionType']) || isValidFunctionalSpecFunctionType(data.functionType))
          && (!data.keys().hasAny(['ownerUid']) || data.ownerUid is string)
          && (!data.keys().hasAny(['ownerName']) || data.ownerName is string)
          && (!data.keys().hasAny(['requirementId']) || data.requirementId is string)
          && (!data.keys().hasAny(['requirementCode']) || data.requirementCode is string)
          && (!data.keys().hasAny(['requirementTitle']) || data.requirementTitle is string)
          && (!data.keys().hasAny(['linkedScreen']) || data.linkedScreen is string)
          && (!data.keys().hasAny(['inputSpec']) || data.inputSpec is string)
          && (!data.keys().hasAny(['businessRule']) || data.businessRule is string)
          && (!data.keys().hasAny(['exceptionRule']) || data.exceptionRule is string)
          && (!data.keys().hasAny(['apiRef']) || data.apiRef is string)
          && (!data.keys().hasAny(['note']) || data.note is string)
          && (!data.keys().hasAny(['reviewStatus']) || data.reviewStatus is string)
          && data.updatedBy == uid()
          && data.updatedAt == request.time;
    }

    // ── users/{uid} bootstrap helpers (PR #355) ───────────────────
    // Path variable userId must be passed into helpers explicitly.
    function userBootstrapKeys() {
      return [
        'userId',
        'email',
        'emailNormalized',
        'displayName',
        'photoURL',
        'provider',
        'status',
        'createdAt',
        'updatedAt',
        'lastLoginAt',
      ];
    }
    function isValidUserBootstrapCreate(userId) {
      let data = request.resource.data;
      return signedIn()
          && userId == uid()
          && data.userId == uid()
          && data.provider == 'google'
          && data.status == 'active'
          && data.email is string
          && data.emailNormalized is string
          && data.displayName is string
          && data.photoURL is string
          && data.emailNormalized == data.email.lower()
          && data.keys().hasOnly(userBootstrapKeys())
          && data.createdAt == request.time
          && data.updatedAt == request.time
          && data.lastLoginAt == request.time;
    }
    function isValidUserBootstrapUpdate(userId) {
      let data = request.resource.data;
      let prev = resource.data;
      return signedIn()
          && userId == uid()
          && data.userId == prev.userId
          && data.userId == uid()
          && data.provider == prev.provider
          && data.status == prev.status
          && data.createdAt == prev.createdAt
          && data.email is string
          && data.emailNormalized is string
          && data.displayName is string
          && data.photoURL is string
          && data.emailNormalized == data.email.lower()
          && data.updatedAt == request.time
          && data.lastLoginAt == request.time
          && data.diff(prev).affectedKeys().hasOnly([
            'email',
            'emailNormalized',
            'displayName',
            'photoURL',
            'updatedAt',
            'lastLoginAt',
          ]);
    }

    // ── users/{userId} ────────────────────────────────────────────
    // PR #355: signed-in user may bootstrap their own users/{uid} doc.
    // Self-read only. No delete. status/provider/createdAt are immutable
    // from the client on update.
    match /users/{userId} {
      allow read: if signedIn() && userId == uid();
      allow create: if isValidUserBootstrapCreate(userId);
      allow update: if isValidUserBootstrapUpdate(userId);
      allow delete: if false;
    }

    // ── tenants/{tenantId} ────────────────────────────────────────
    // tenant management UI is deferred. Rules stay fully closed so
    // no client can enumerate or read the tenants collection yet.
    match /tenants/{tenantId} {
      allow read, write: if false;
    }

    // ── projects/{projectId}/** ───────────────────────────────────
    // Every read on a project or its subcollections requires an
    // active member document under projects/{projectId}/members/{uid}.
    // Writes are closed everywhere here; role-scoped writes land later.
    match /projects/{projectId} {
      allow get, list: if canReadProject(projectId);
      allow create: if isValidProjectCreate(projectId);
      allow update, delete: if false;

      match /members/{memberUid} {
        allow get: if signedIn() && (
          memberUid == uid() ||
          canReadProject(projectId)
        );
        allow list: if signedIn() && (
          isOwnMembershipRecord() ||
          canReadProject(projectId)
        );
        allow create: if isValidOwnerMemberCreate(projectId, memberUid);
        allow update, delete: if false;
      }

      match /requirements/{requirementId} {
        allow get, list: if canReadProject(projectId);
        allow create: if isValidRequirementCreate(projectId, requirementId);
        allow update: if isValidRequirementUpdate(projectId, requirementId);
        allow delete: if false;
      }

      match /functionalSpecifications/{functionalSpecId} {
        allow get, list: if canReadProject(projectId);
        allow create: if isValidFunctionalSpecCreate(projectId, functionalSpecId);
        allow update: if isValidFunctionalSpecUpdate(projectId, functionalSpecId);
        allow delete: if false;
      }

      match /counters/{counterId} {
        allow get, list: if canReadProject(projectId);
        allow create, update: if isRequirementWriter(projectId)
            && (
              (counterId == 'requirements' && isValidRequirementsCounterWrite())
              || (counterId == 'functionalSpecifications' && isValidFunctionalSpecificationsCounterWrite())
            );
        allow delete: if false;
      }

      match /wbsItems/{wbsItemId} {
        allow get, list: if canReadProject(projectId);
        allow create, update, delete: if false;
      }

      match /screenSpecs/{screenSpecId} {
        allow get, list: if canReadProject(projectId);
        allow create, update, delete: if false;
      }

      match /screenFields/{fieldId} {
        allow get, list: if canReadProject(projectId);
        allow create, update, delete: if false;
      }

      match /screenActions/{actionId} {
        allow get, list: if canReadProject(projectId);
        allow create, update, delete: if false;
      }

      match /artifactLinks/{linkId} {
        allow get, list: if canReadProject(projectId);
        allow create, update, delete: if false;
      }
    }

    // ── collectionGroup('members') discovery ──────────────────────
    // Login routing does not know projectId yet. Allow signed-in users
    // to read only their own membership records through collectionGroup
    // queries constrained by userId or emailNormalized. Writes stay closed.
    match /{path=**}/members/{memberUid} {
      allow get, list: if isOwnMembershipRecord();
      allow create, update, delete: if false;
    }

    // ── Catch-all deny ────────────────────────────────────────────
    // Anything not explicitly matched above is denied. Never insert
    // a broader `allow read, write: if true` rule here — even for
    // debugging.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
